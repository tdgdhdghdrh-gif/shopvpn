generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String
  password            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isAdmin             Boolean              @default(false)
  balance             Float                @default(0)
  discountExpiry      DateTime?
  referralCode        String?              @unique
  referralCount       Int                  @default(0)
  referredBy          String?
  referredByIP        String?
  totalReferralEarned Float                @default(0)
  chatMessages        ChatMessage[]
  orders              Order[]
  referralHistory     ReferralHistory[]
  referralIPTracking  ReferralIPTracking[]
  topups              TopUp[]
  vlessPublicOrders   VlessPublicOrder[]
  vpnOrders           VpnOrder[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  imageUrl    String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  buyerId      String
  productId    String
  productName  String
  productPrice Float
  productImage String?
  status       String   @default("COMPLETED")
  createdAt    DateTime @default(now())
  buyer        User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
}

model TopUp {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  method    String   @default("admin")
  note      String?
  createdBy String?
  createdAt DateTime @default(now())
  reference String?  @unique
  slipUrl   String?
  status    String   @default("SUCCESS")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id                String   @id @default(cuid())
  truemoneyPhone    String?
  truemoneyApiKey   String?
  slipApiKey        String?
  bankReceiverName  String?  @default("พันวิลา")
  bankAccountNumber String?
  promptpayNumber   String?
  updatedAt         DateTime @updatedAt
  qrCodeImage       String?
  backgroundImage   String?
  googleApiKey      String?
  siteLogo          String?
  siteName          String?  @default("SimonVPNShop")
  vpnDailyPrice     Float    @default(4)
  vpnMonthlyPrice   Float    @default(100)
  vpnWeeklyPrice    Float    @default(25)
  theme             String   @default("cyber")
}

model VpnServer {
  id           String     @id @default(cuid())
  name         String
  host         String
  port         Int
  path         String
  username     String
  password     String
  inboundId    Int
  protocol     String     @default("vless")
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  flag         String     @default("🇸🇬")
  flow         String     @default("xtls-rprx")
  load         Int        @default(45)
  network      String     @default("ws")
  ping         Int        @default(15)
  sni          String     @default("google.co.th")
  status       String     @default("Online")
  tlsType      String     @default("Reality")
  supportsAis  Boolean    @default(true)
  supportsTrue Boolean    @default(false)
  supportsDtac Boolean    @default(false)
  clientPort   Int        @default(443)
  category     String     @default("general")
  speed        Int        @default(1000)
  orders       VpnOrder[]
}

model VpnOrder {
  id          String    @id @default(cuid())
  userId      String
  serverId    String
  packageType String
  price       Float
  duration    Int
  clientUUID  String
  remark      String
  subId       String
  vlessLink   String
  expiryTime  DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  server      VpnServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VlessPublicOrder {
  id        String   @id @default(cuid())
  userId    String
  country   String
  flag      String
  hostname  String
  port      String
  uuid      String
  vlessLink String
  price     Float    @default(1)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model ReferralHistory {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String?
  referredName String?
  amount       Float
  type         String   @default("TOPUP_REWARD")
  createdAt    DateTime @default(now())
  referrer     User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([createdAt])
}

model ReferralIPTracking {
  id         String   @id @default(cuid())
  ipAddress  String
  userId     String
  referrerId String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ipAddress])
  @@index([createdAt])
  @@index([userId])
}
